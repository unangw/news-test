# frozen_string_literal: true

default_platform(:ios)

# --- CENTRALIZED CONFIGURATION ---
SHARED_CONFIG = {
  project: ENV.fetch("PROJECT_PATH", "News.xcodeproj"),
  scheme: ENV.fetch("SCHEME", "News"),
  derived_data_path: ENV.fetch("DD_PATH", File.join(Dir.pwd, "build", "derived_data")),
  destination: ENV.fetch("DESTINATION", "platform=iOS Simulator,name=iPhone 17 Pro,OS=latest")
}.freeze

SHARED_PATHS = {
  build_dir: File.join(Dir.pwd, "build"),
  source_packages: ENV.fetch("CLONED_SOURCE_PACKAGES_DIR", File.join(Dir.pwd, "build", "SourcePackages")),
  lint_report: File.join(Dir.pwd, "swiftlint-report.html")
}.freeze

# --- HELPER METHODS ---
def resolved_xctestrun
  pattern = File.join(SHARED_CONFIG[:derived_data_path], "Build", "Products", "**", "*.xctestrun")
  path = Dir.glob(pattern).first
  UI.user_error!("Could not find .xctestrun under #{SHARED_CONFIG[:derived_data_path]}") unless path
  path
end

def get_result_bundle_path(build_num, type)
  File.join(SHARED_PATHS[:build_dir], "#{type}-#{build_num}.xcresult")
end

def swiftlint_executable
  # Keep existing search logic
  from_env = ENV["SWIFTLINT_EXECUTABLE"].to_s.strip
  return from_env if !from_env.empty? && File.executable?(from_env)
  %w[/opt/homebrew/bin/swiftlint /usr/local/bin/swiftlint].each { |p| return p if File.executable?(p) }
  ENV["PATH"].to_s.split(File::PATH_SEPARATOR).each { |dir| 
    candidate = File.join(dir, "swiftlint")
    return candidate if File.executable?(candidate) 
  }
  nil
end

platform :ios do
  lane :compile_for_testing do
    run_tests(
      project: SHARED_CONFIG[:project],
      scheme: SHARED_CONFIG[:scheme],
      destination: SHARED_CONFIG[:destination],
      derived_data_path: SHARED_CONFIG[:derived_data_path],
      build_for_testing: true,
      xcargs: "-clonedSourcePackagesDirPath '#{SHARED_PATHS[:source_packages]}'"
    )
  end

  lane :ci_lint do
    exe = swiftlint_executable
    if exe.nil?
      File.write(SHARED_PATHS[:lint_report], "<html><body><p>SwiftLint executable not found.</p></body></html>")
    else
      swiftlint(mode: :lint, reporter: "html", output_file: SHARED_PATHS[:lint_report], ignore_exit_status: true, executable: exe)
    end
  end

  lane :ci_unit_tests do |options|
    run_tests(
      project: SHARED_CONFIG[:project],
      scheme: SHARED_CONFIG[:scheme],
      xctestrun: resolved_xctestrun,
      destination: SHARED_CONFIG[:destination],
      derived_data_path: SHARED_CONFIG[:derived_data_path],
      test_without_building: true,
      only_testing: ["NewsTests"],
      result_bundle_path: get_result_bundle_path(options[:JENKINS_VERSION_CODE] || "local", "unit-test")
    )
  end

  lane :ci_ui_tests do |options|
    run_tests(
      project: SHARED_CONFIG[:project],
      scheme: SHARED_CONFIG[:scheme],
      xctestrun: resolved_xctestrun,
      destination: SHARED_CONFIG[:destination],
      derived_data_path: SHARED_CONFIG[:derived_data_path],
      test_without_building: true,
      only_testing: ["NewsUITests"],
      parallel_testing: false,
      result_bundle_path: get_result_bundle_path(options[:JENKINS_VERSION_CODE] || "local", "ui-test")
    )
  end

  lane :test_with_testplan do |options|
    run_tests(
      project: SHARED_CONFIG[:project],
      scheme: SHARED_CONFIG[:scheme],
      xctestrun: resolved_xctestrun,
      destination: SHARED_CONFIG[:destination],
      derived_data_path: SHARED_CONFIG[:derived_data_path],
      test_without_building: true,
      testplan: ENV.fetch("TEST_PLAN", "News"),
      parallel_testing: false,
      result_bundle_path: get_result_bundle_path(options[:JENKINS_VERSION_CODE] || "local", "testplan")
    )
  end

  lane :build_for_release do
    UI.important("Placeholder for: build_ios_app (gym) using project: #{SHARED_CONFIG[:project]}")
  end

  lane :release_to_firebase do
    UI.important("Placeholder for: firebase_app_distribution")
  end
end
