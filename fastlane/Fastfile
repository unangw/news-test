# frozen_string_literal: true

default_platform(:ios)

def resolved_xctestrun
  dd = ENV.fetch("DD_PATH", File.join(Dir.pwd, "build", "derived_data"))
  pattern = File.join(dd, "Build", "Products", "**", "*.xctestrun")
  path = Dir.glob(pattern).first
  UI.user_error!("Could not find .xctestrun under #{dd}") unless path

  UI.message("Using xctestrun: #{path}")
  path
end

def simulator_destination
  ENV.fetch("DESTINATION", "platform=iOS Simulator,name=iPhone 17 Pro,OS=latest")
end

def swiftlint_executable
  from_env = ENV["SWIFTLINT_EXECUTABLE"].to_s.strip
  return from_env if !from_env.empty? && File.executable?(from_env)

  %w[
    /opt/homebrew/bin/swiftlint
    /usr/local/bin/swiftlint
  ].each do |path|
    return path if File.executable?(path)
  end

  ENV["PATH"].to_s.split(File::PATH_SEPARATOR).each do |dir|
    candidate = File.join(dir, "swiftlint")
    return candidate if File.executable?(candidate)
  end

  nil
end

platform :ios do
  desc "run_tests with build_for_testing (same as scan; produces .xctestrun for later steps)"
  lane :compile_for_testing do
    run_tests(
      project: ENV.fetch("PROJECT_PATH", "News.xcodeproj"),
      scheme: ENV.fetch("SCHEME", "News"),
      destination: simulator_destination,
      derived_data_path: ENV.fetch("DD_PATH", File.join(Dir.pwd, "build", "derived_data")),
      build_for_testing: true
    )
  end

  desc "SwiftLint HTML report (non-failing; same spirit as Jenkins `|| true`)"
  lane :ci_lint do
    exe = swiftlint_executable
    if exe.nil?
      UI.important("SwiftLint not found (set SWIFTLINT_EXECUTABLE or install swiftlint). Skipping lint; writing placeholder report.")
      File.write(File.join(Dir.pwd, "swiftlint-report.html"), "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><title>SwiftLint</title></head><body><p>SwiftLint executable not found on this machine.</p></body></html>\n")
    else
      UI.message("Using SwiftLint at: #{exe}")
      swiftlint(
        mode: :lint,
        reporter: "html",
        output_file: "swiftlint-report.html",
        ignore_exit_status: true,
        executable: exe
      )
    end
  end

  desc "Unit tests using existing .xctestrun"
  lane :ci_unit_tests do
    run_tests(
      project: ENV.fetch("PROJECT_PATH", "News.xcodeproj"),
      scheme: ENV.fetch("SCHEME", "News"),
      xctestrun: resolved_xctestrun,
      destination: simulator_destination,
      derived_data_path: ENV.fetch("DD_PATH", File.join(Dir.pwd, "build", "derived_data")),
      test_without_building: true,
      only_testing: ["NewsTests"],
      result_bundle_path: File.join(Dir.pwd, "build", "unit_test.xcresult")
    )
  end

  desc "UI tests using existing .xctestrun (parallel testing disabled)"
  lane :ci_ui_tests do
    run_tests(
      project: ENV.fetch("PROJECT_PATH", "News.xcodeproj"),
      scheme: ENV.fetch("SCHEME", "News"),
      xctestrun: resolved_xctestrun,
      destination: simulator_destination,
      derived_data_path: ENV.fetch("DD_PATH", File.join(Dir.pwd, "build", "derived_data")),
      test_without_building: true,
      only_testing: ["NewsUITests"],
      parallel_testing: false,
      result_bundle_path: File.join(Dir.pwd, "build", "ui_test.xcresult")
    )
  end

  desc "Configure gym / signing, then enable this lane for release IPA builds"
  lane :build_for_release do
    UI.important("Placeholder: add build_ios_app (gym) and signing before using in CI.")
  end

  desc "Configure firebase_app_distribution before using in CI"
  lane :release_to_firebase do
    UI.important("Placeholder: add firebase_app_distribution when ready.")
  end
end
